{
  "name": "packflow-erp",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd client && npm install",
    "build": "cd client && npm install && npm run build",
    "start": "serve -s client/dist -l ${PORT:-3000}"
  },
  "dependencies": {
    "serve": "^14.2.3"
  }
}
