generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Generic per-table store. The frontend keeps its existing data model (one JSON
// array per "table", e.g. orders / inv_rolls / auth_users); each is stored here
// as one row keyed by the table name. This makes the whole app's data shared
// across devices without a bespoke schema/endpoint per entity.
model Store {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}
