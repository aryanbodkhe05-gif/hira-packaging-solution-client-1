# ── Hira ERP shared data-store backend ──────────────────────────────────────
# Postgres connection string (Dokploy gives you one when you add a Postgres service)
DATABASE_URL="postgresql://postgres:password@localhost:5432/hira_erp"

# Port the server listens on (Dokploy maps your domain to this)
PORT=3001

# Allowed browser origin for CORS in local dev (Vite). Combined prod deploy is
# same-origin, so this is dev-only.
CLIENT_URL="http://localhost:5173"

# Optional: require this token (sent as x-sync-token header) on all /api/data
# requests. Leave unset for an open API on a trusted network.
# APP_SYNC_TOKEN="a-long-random-shared-secret"
