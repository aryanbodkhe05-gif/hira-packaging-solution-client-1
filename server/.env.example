# ── PackFlow ERP server (auth + users) ──────────────────────────────────────
# Postgres connection string (Dokploy provides one when you create a Postgres service)
DATABASE_URL="postgresql://postgres:password@localhost:5432/packflow_erp"

# REQUIRED. Long random string — the server refuses to start without it.
# Generate one with:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"

# Port the server listens on (Dokploy maps your domain to this)
PORT=3001

# Allowed browser origin for CORS in local dev (Vite). In the combined
# production deployment the API + SPA share an origin, so this is dev-only.
CLIENT_URL="http://localhost:5173"

# Optional: override the seeded Developer account (recommended for production).
# If unset, defaults to Aryan Bodkhe / aryanbodkhe / aryandeveloper — ROTATE IT.
# DEV_NAME="Aryan Bodkhe"
# DEV_USERNAME="aryanbodkhe"
# DEV_PASSWORD="use-a-strong-password-here"
